<?xml version="1.0" encoding="utf-8"?>
<!--
  医疗设备监控上位机系统 — NuGet 依赖清单
  本文件为标准 packages.config 格式，供 install-packages.ps1 脚本调用。
  配合单机版架构使用，分布式扩展依赖请在后续阶段按需添加。
-->
<packages>
  <!-- MVVM 框架（微软官方维护，替代已停更的 MvvmLightLibs） -->
  <package id="CommunityToolkit.Mvvm" version="8.2.2" targetFramework="net48" />

  <!-- DI 容器 -->
  <package id="Microsoft.Extensions.DependencyInjection" version="6.0.1" targetFramework="net48" />

  <!-- 图表控件（医疗波形实时显示） -->
  <package id="OxyPlot.WindowsForms" version="2.1.2" targetFramework="net48" />

  <!-- UI 样式框架 -->
  <package id="MaterialSkin.2" version="2.3.1" targetFramework="net48" />

  <!-- Modbus 通信协议 -->
  <package id="NModbus" version="3.0.14" targetFramework="net48" />

  <!-- 数据库 -->
  <package id="MySql.Data.EntityFramework" version="8.0.33" targetFramework="net48" />

  <!-- 日志（审计日志 + 运行日志） -->
  <package id="Serilog" version="2.12.0" targetFramework="net48" />
  <package id="Serilog.Sinks.File" version="5.0.0" targetFramework="net48" />
  <package id="Serilog.Sinks.Console" version="4.1.0" targetFramework="net48" />

  <!-- 工具库 -->
  <package id="Newtonsoft.Json" version="13.0.3" targetFramework="net48" />
  <package id="AutoMapper" version="10.1.1" targetFramework="net48" />
  <package id="FluentValidation" version="10.4.0" targetFramework="net48" />
</packages>

<!--
  分布式扩展依赖（本阶段不启用，仅作参考）：
  <package id="StackExchange.Redis" version="2.6.122" targetFramework="net48" />
  <package id="RabbitMQ.Client" version="6.8.1" targetFramework="net48" />
  <package id="Microsoft.AspNet.WebApi" version="5.2.9" targetFramework="net48" />
  <package id="Swashbuckle.AspNetCore" version="5.6.3" targetFramework="net48" />
-->
