<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>

    <!-- ============================================================ -->
    <!-- SQL Server 连接字符串                                         -->
    <!-- 修改 Server / User ID / Password 为你本机的实际值              -->
    <!-- ============================================================ -->
    <connectionStrings>
        <add name="MedicalMonitorDb"
             connectionString="Server=DDENGK;Database=Medical_Device_Monitor_DB;User ID=sa;Password=root;TrustServerCertificate=True;"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
</configuration>
